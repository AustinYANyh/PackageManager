<Window x:Class="PackageManager.Views.LanTransferConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        Title="接收文件"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F8F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="收到新的文件传输请求"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#1F2A25"/>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="14"
                CornerRadius="16"
                Background="White"
                BorderBrush="#18000000"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{Binding SenderLabel}" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Margin="0,8,0,0" Text="{Binding SummaryText}" Foreground="#55615A" TextWrapping="Wrap"/>
                <TextBlock Margin="0,8,0,0" Text="{Binding SaveDirectory}" Foreground="#1A6A5F" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,16,0,8"
                   Text="顶层内容"
                   FontWeight="Bold"
                   Foreground="#55615A"/>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#18000000"
                BorderThickness="1"
                CornerRadius="16">
            <ListBox ItemsSource="{Binding TopLevelNames}"
                     BorderThickness="0"
                     Background="Transparent"
                     Margin="8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,8" Margin="0,0,0,6" Background="#FFF7F8F5" CornerRadius="10">
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <button:CButton Content="拒绝"
                            Width="90"
                            Height="34"
                            Margin="0,0,10,0"
                            Click="RejectButton_Click"/>
            <button:CButton Content="接收"
                            Width="90"
                            Height="34"
                            Click="AcceptButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
