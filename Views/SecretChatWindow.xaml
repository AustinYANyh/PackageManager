<Window x:Class="PackageManager.Views.SecretChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        Title="密语"
        Width="560"
        Height="640"
        MinWidth="460"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#101514">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="18" Background="#17211E">
            <StackPanel>
                <TextBlock Text="{Binding PeerTitle}" FontSize="20" FontWeight="Bold" Foreground="#F3FFF9" TextTrimming="CharacterEllipsis"/>
                <TextBlock Margin="0,6,0,0" Text="{Binding ProtectionText}" Foreground="#9DD8C8" TextWrapping="Wrap"/>
                <TextBlock Margin="0,4,0,0" Text="密语不保存，已读后 5 秒销毁；系统截图/录屏会黑屏，但无法阻止手机拍屏。" Foreground="#B9C9C2" TextWrapping="Wrap"/>
                <TextBlock Margin="0,4,0,0" Text="{Binding StatusText}" Foreground="#83F0C8" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="14" Padding="10" Background="#0B0E0D" CornerRadius="18">
            <ScrollViewer x:Name="MessagesScrollViewer"
                          VerticalScrollBarVisibility="Hidden"
                          Focusable="False">
                <ItemsControl ItemsSource="{Binding Messages}"
                              Focusable="False"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="BubbleBorder"
                                        Grid.Column="0"
                                        Padding="12"
                                        Background="#1D2A26"
                                        CornerRadius="14"
                                        HorizontalAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CreatedAtText}" Foreground="#8FB5A9" FontSize="11"/>
                                        <TextBlock Margin="0,6,0,0" Text="{Binding Text}" FontSize="15" Foreground="#F4FFF9" TextWrapping="Wrap"/>
                                        <TextBlock Margin="0,8,0,0" Text="{Binding StateText}" Foreground="#83F0C8" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                    <Setter TargetName="BubbleBorder" Property="Grid.Column" Value="1"/>
                                    <Setter TargetName="BubbleBorder" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="BubbleBorder" Property="Background" Value="#176F63"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="14,0,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MessageTextBox"
                     MinHeight="42"
                     MaxLength="2000"
                     Padding="12"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     ContextMenu="{x:Null}"
                     PreviewKeyDown="MessageTextBox_PreviewKeyDown"/>
            <button:CButton Grid.Column="1"
                            Width="92"
                            Height="42"
                            Margin="10,0,0,0"
                            Content="发送"
                            Click="SendButton_Click"/>
        </Grid>

        <Border x:Name="PrivacyOverlay"
                Grid.RowSpan="3"
                Background="Black"
                Visibility="Collapsed">
            <TextBlock Text="密语已遮蔽"
                       Foreground="#7C8A84"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
