<Page x:Class="PackageManager.Views.LanTransferPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
      xmlns:conv="clr-namespace:PackageManager.Converters"
      mc:Ignorable="d"
      Background="#F5F6F2">
    <Page.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#18000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>

        <Style x:Key="StretchListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F2A25"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5E6A63"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="RootScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="750"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="18,16,18,16"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="文件传输"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#1F2A25"/>
                        <TextBlock Margin="0,8,16,0"
                                   Text="{Binding HeaderSummaryText}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <button:CButton Content="返回主页"
                                        Width="96"
                                        Height="34"
                                        Margin="0,0,8,0"
                                        Click="BackButton_Click"/>
                        <button:CButton Content="打开收件箱"
                                        Width="96"
                                        Height="34"
                                        Margin="0,0,8,0"
                                        Click="OpenInboxButton_Click"/>
                        <button:CButton Content="打开日志"
                                        Width="96"
                                        Height="34"
                                        Click="OpenLogsButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.98*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.16*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="0.98*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Height="750"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="设备与连接" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="优先从在线设备里选择目标；找不到时再手动输入 IP 或主机名连接。"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,16,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="118"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Height="34"
                                     Text="{Binding ManualAddress, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"/>
                            <button:CButton Grid.Column="2"
                                            Height="34"
                                            Content="手动连接"
                                            Click="ManualConnectButton_Click"/>
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Text="当前目标"
                                   FontWeight="Bold"
                                   Foreground="#5E6A63"/>

                        <Border Grid.Row="3"
                                Margin="0,8,0,14"
                                Padding="14"
                                Background="#F7FAF8"
                                BorderBrush="#15000000"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedPeerSummaryTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#20312A"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SelectedPeerSummaryText}"
                                           Style="{StaticResource MutedTextStyle}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="在线设备"
                                       FontWeight="Bold"
                                       Foreground="#5E6A63"/>

                            <ListBox Grid.Row="1"
                                     Margin="0,8,0,0"
                                     ItemsSource="{Binding Service.Peers}"
                                     SelectedItem="{Binding SelectedPeer, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource StretchListBoxItemStyle}"
                                     PreviewMouseWheel="InnerScrollHost_PreviewMouseWheel"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="#FAFCFA"
                                                BorderBrush="#18000000"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                HorizontalAlignment="Stretch">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="{Binding DisplayLabel}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding EndpointDisplay}"
                                                               Foreground="#5E6A63"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               Text="{Binding StatusSummaryText}"
                                                               Foreground="#1A6A5F"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                                <Grid Grid.Row="2" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding SecretChatText}"
                                                               Foreground="#7D6A1A"
                                                               FontSize="12"/>
                                                    <Border Grid.Column="1"
                                                            MinWidth="22"
                                                            Height="20"
                                                            Margin="8,0,0,0"
                                                            Padding="6,0"
                                                            Background="#E64D3D"
                                                            CornerRadius="10"
                                                            Visibility="{Binding HasSecretUnread, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding SecretChatBadgeText}"
                                                                   Foreground="White"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource PanelBorderStyle}"
                        Height="750"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="发送内容" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="把文件或文件夹集中放在这里，确认目标后一次发送。保留拖拽、批量选择和清理操作。"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Margin="0,16,0,14"
                                     Columns="4">
                            <button:CButton
                                            Content="添加文件"
                                            Height="32"
                                            Padding="8,4"
                                            Margin="0,0,8,0"
                                            Click="AddFilesButton_Click"/>
                            <button:CButton
                                            Content="添加文件夹"
                                            Height="32"
                                            Padding="8,4"
                                            Margin="0,0,8,0"
                                            Click="AddFolderButton_Click"/>
                            <button:CButton
                                            Content="移除选中"
                                            Height="32"
                                            Padding="8,4"
                                            Margin="0,0,8,0"
                                            Click="RemoveQueuedButton_Click"/>
                            <button:CButton
                                            Content="清空"
                                            Height="32"
                                            Padding="8,4"
                                            Margin="0,0,0,0"
                                            Click="ClearQueuedButton_Click"/>
                        </UniformGrid>

                        <Border Grid.Row="2"
                                Background="#F8FAF8"
                                BorderBrush="#18000000"
                                BorderThickness="1"
                                CornerRadius="16"
                                AllowDrop="True"
                                DragOver="DropZone_DragOver"
                                Drop="DropZone_Drop">
                            <Grid Margin="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="拖拽文件或文件夹到这里"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#21312A"/>
                                <TextBlock Grid.Row="1"
                                           Margin="0,6,0,12"
                                           Text="{Binding QueueSummaryText}"
                                           Style="{StaticResource MutedTextStyle}"/>

                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding QueuedItems}"
                                         SelectedItem="{Binding SelectedQueuedItem, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource StretchListBoxItemStyle}"
                                         PreviewMouseWheel="InnerScrollHost_PreviewMouseWheel"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="12"
                                                    Background="White"
                                                    BorderBrush="#17000000"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    HorizontalAlignment="Stretch"
                                                    Height="82">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,4,0,0"
                                                               Text="{Binding FullPath}"
                                                               Foreground="#5E6A63"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Row="2"
                                                               Margin="0,4,0,0"
                                                               Text="{Binding SummaryText}"
                                                               Foreground="#1A6A5F"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,14,0,0"
                                Padding="14"
                                Background="#F7FAF8"
                                BorderBrush="#15000000"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="发送准备"
                                               FontWeight="Bold"
                                               Foreground="#20312A"/>
                                    <TextBlock Margin="0,5,0,0"
                                               Text="{Binding SendTargetSummaryText}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                    <button:CButton Width="92"
                                                    Height="36"
                                                    Margin="0,0,10,0"
                                                    Content="密语"
                                                    Click="SecretChatButton_Click"/>
                                    <button:CButton Width="142"
                                                    Height="36"
                                                    Content="发送到当前目标"
                                                    Click="SendButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource PanelBorderStyle}"
                        Height="750"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="传输状态" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="保留现有待接收通知和确认流程，这里主要承接待确认和进行中的状态查看。"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,14,0,14"
                                Padding="14"
                                Background="#F7FAF8"
                                BorderBrush="#15000000"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="待确认请求"
                                               FontWeight="Bold"
                                               Foreground="#20312A"/>
                                    <TextBlock Margin="0,5,0,0"
                                               Text="{Binding PendingRequestSummaryText}"
                                               Style="{StaticResource MutedTextStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="进行中的传输"
                                               FontWeight="Bold"
                                               Foreground="#20312A"/>
                                    <TextBlock Margin="0,5,0,0"
                                               Text="{Binding ActiveTransferSummaryText}"
                                               Style="{StaticResource MutedTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="待确认请求"
                                       FontWeight="Bold"
                                       Foreground="#5E6A63"/>
                            <ListBox Grid.Row="1"
                                     Margin="0,8,0,14"
                                     ItemsSource="{Binding Service.PendingRequests}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MaxHeight="128"
                                     ItemContainerStyle="{StaticResource StretchListBoxItemStyle}"
                                     PreviewMouseWheel="InnerScrollHost_PreviewMouseWheel"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                Background="#FAFCFA"
                                                BorderBrush="#18000000"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SenderLabel}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding TopLevelSummary}"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding StatusText}"
                                                           Foreground="#1A6A5F"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Grid.Row="2"
                                       Text="进行中的传输"
                                       FontWeight="Bold"
                                       Foreground="#5E6A63"/>
                            <ListBox Grid.Row="3"
                                     Margin="0,8,0,0"
                                     ItemsSource="{Binding Service.ActiveTransfers}"
                                     SelectedItem="{Binding SelectedActiveTransfer, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource StretchListBoxItemStyle}"
                                     PreviewMouseWheel="InnerScrollHost_PreviewMouseWheel"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                Background="#FAFCFA"
                                                BorderBrush="#18000000"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DirectionText}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding PeerDisplayName}"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding Summary}"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding ProgressText}"
                                                           Foreground="#1A6A5F"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,14,0,0">
                            <button:CButton Content="取消选中传输"
                                            Width="120"
                                            Height="34"
                                            Click="CancelTransferButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Expander Grid.Row="2"
                      Margin="0,16,0,0"
                      Background="Transparent"
                      IsExpanded="False">
                <Expander.Header>
                    <StackPanel>
                        <TextBlock Text="最近传输记录"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1F2A25"
                                   Margin="0,16,0,0"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding HistorySummaryText}"
                                   Foreground="#5E6A63"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander.Header>

                <Border Margin="0,10,0,0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="16">
                    <ListBox ItemsSource="{Binding Service.TransferHistory}"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="220"
                             ItemContainerStyle="{StaticResource StretchListBoxItemStyle}"
                             PreviewMouseWheel="InnerScrollHost_PreviewMouseWheel"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10,10,12,10"
                                        Background="#FAFCFA"
                                        BorderBrush="#18000000"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.3*"/>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="1.4*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DirectionSummaryText}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   Text="{Binding PeerSummaryText}"
                                                   Foreground="#5E6A63"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Margin="12,0,0,0"
                                                   Text="{Binding StatusTimeText}"
                                                   Foreground="#1A6A5F"
                                                   TextWrapping="NoWrap"/>
                                        <TextBlock Grid.Column="3"
                                                   Margin="12,0,0,0"
                                                   Text="{Binding TargetPath}"
                                                   Foreground="#5E6A63"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Expander>
        </Grid>
    </ScrollViewer>
</Page>
