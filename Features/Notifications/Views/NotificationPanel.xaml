<UserControl x:Class="PackageManager.Features.Notifications.Views.NotificationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
             Width="360" MaxHeight="480">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="8" BorderBrush="#22000000" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <Grid Grid.Row="0" Margin="16,12,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <controls:CTextBlock Text="通知中心" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="全部已读" FontSize="12" Foreground="#2B7FFF"
                           Cursor="Hand" VerticalAlignment="Center"
                           MouseLeftButtonUp="MarkAllAsRead_Click">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Border Grid.Row="0" BorderBrush="#0F000000" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

            <!-- 通知列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="370">
                <ItemsControl x:Name="NotificationList" ItemsSource="{Binding Notifications}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" Cursor="Hand"
                                    MouseLeftButtonUp="NotificationItem_Click"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#08000000"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                <Setter Property="Background" Value="#F5F8FF"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 级别图标 -->
                                    <TextBlock Grid.Column="0" Grid.RowSpan="2"
                                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               VerticalAlignment="Top" Margin="0,2,0,0"
                                               x:Name="LevelIcon"/>

                                    <!-- 标题 -->
                                    <controls:CTextBlock Grid.Column="1" Grid.Row="0"
                                                        Text="{Binding Title}"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Margin="0,0,8,0"
                                                        TextTrimming="CharacterEllipsis"/>

                                    <!-- 时间戳 -->
                                    <TextBlock Grid.Column="2" Grid.Row="0"
                                               Text="{Binding TimestampText}"
                                               FontSize="11" Foreground="#999999"
                                               VerticalAlignment="Center"/>

                                    <!-- 消息 -->
                                    <controls:CTextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                        Text="{Binding Message}"
                                                        FontSize="12" Foreground="#666666"
                                                        TextTrimming="CharacterEllipsis"
                                                        MaxHeight="36" Margin="0,2,0,0"/>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="Success">
                                    <Setter TargetName="LevelIcon" Property="Text" Value="&#xE8FB;"/>
                                    <Setter TargetName="LevelIcon" Property="Foreground" Value="#107C10"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                    <Setter TargetName="LevelIcon" Property="Text" Value="&#xE7BA;"/>
                                    <Setter TargetName="LevelIcon" Property="Foreground" Value="#FF8C00"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                    <Setter TargetName="LevelIcon" Property="Text" Value="&#xE711;"/>
                                    <Setter TargetName="LevelIcon" Property="Foreground" Value="#E81123"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="Info">
                                    <Setter TargetName="LevelIcon" Property="Text" Value="&#xE946;"/>
                                    <Setter TargetName="LevelIcon" Property="Foreground" Value="#2B7FFF"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 空状态提示 -->
            <StackPanel Grid.Row="1" x:Name="EmptyState"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed" Margin="0,40">
                <TextBlock Text="&#xEC42;" FontFamily="Segoe MDL2 Assets"
                           FontSize="32" Foreground="#CCCCCC"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <controls:CTextBlock Text="暂无通知" FontSize="13"
                                    Foreground="#999999" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 底部 -->
            <Border Grid.Row="2" BorderBrush="#0F000000" BorderThickness="0,1,0,0">
                <TextBlock Text="清除全部" FontSize="12" Foreground="#999999"
                           Cursor="Hand" Margin="16,8" HorizontalAlignment="Left"
                           MouseLeftButtonUp="ClearAll_Click">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#E81123"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</UserControl>
