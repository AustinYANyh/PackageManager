<Window x:Class="PackageManager.Views.KanBan.PingCodeAiExecutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        Title="PingCode AI 执行"
        Height="720"
        Width="980"
        WindowStartupLocation="CenterOwner"
        MinHeight="560"
        MinWidth="820">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14" CornerRadius="8" BorderBrush="#D7E3F4" BorderThickness="1" Background="#F7FAFF">
            <StackPanel>
                <TextBlock Text="{Binding HeaderText}" FontSize="18" FontWeight="SemiBold" Foreground="#1F2937" />
                <TextBlock Text="{Binding SubHeaderText}" Margin="0,6,0,0" Foreground="#4B5563" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="目标仓库" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" />
            <controls:CComboBox Grid.Column="1"
                      ItemsSource="{Binding Repositories}"
                      SelectedItem="{Binding SelectedRepository}"
                      DisplayMemberPath="Name"
                      MinHeight="30" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="提炼出的链接与图片" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <controls:CListView Grid.Row="0" ItemsSource="{Binding Links}"
                                        BorderThickness="0"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <controls:CListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6" Margin="0,0,0,6" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Category}" FontWeight="SemiBold" Foreground="#2563EB" />
                                        <TextBlock Text="{Binding Url}" TextWrapping="Wrap" Foreground="#111827" Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding Context}" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </controls:CListView.ItemTemplate>
                    </controls:CListView>
                    <TextBlock Grid.Row="1" Text="已提取图片" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#1F2937" />
                    <controls:CListView Grid.Row="2" ItemsSource="{Binding DownloadedImages}"
                                        BorderThickness="0"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <controls:CListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4" Margin="0,0,0,4" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                    <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" Foreground="#374151" />
                                </Border>
                            </DataTemplate>
                        </controls:CListView.ItemTemplate>
                    </controls:CListView>
                    <TextBlock Grid.Row="3" Text="已下载内网页面资源" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#1F2937" />
                    <controls:CListView Grid.Row="4" ItemsSource="{Binding DownloadedIntranetResources}"
                                        BorderThickness="0"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <controls:CListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4" Margin="0,0,0,4" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                    <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" Foreground="#374151" />
                                </Border>
                            </DataTemplate>
                        </controls:CListView.ItemTemplate>
                    </controls:CListView>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Prompt（可编辑）">
                <TextBox Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="NoWrap" />
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="#6B7280" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <button:CButton Content="恢复初始 Prompt" MinWidth="110" Margin="0,0,8,0" Click="RestorePrompt_Click" />
                <button:CButton Content="复制 Prompt" MinWidth="90" Margin="0,0,8,0" Click="CopyPrompt_Click" />
                <button:CButton Content="Claude 执行" MinWidth="100" Margin="0,0,8,0" Click="ClaudeExecute_Click" />
                <button:CButton Content="Codex 执行" MinWidth="100" Margin="0,0,8,0" Click="CodexExecute_Click" />
                <button:CButton Content="取消" MinWidth="76" Click="Cancel_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
