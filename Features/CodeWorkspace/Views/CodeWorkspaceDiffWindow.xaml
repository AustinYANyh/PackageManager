<Window x:Class="PackageManager.Features.CodeWorkspace.Views.CodeWorkspaceDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        xmlns:diff="clr-namespace:DiffPlex.Wpf.Controls;assembly=DiffPlex.Wpf"
        Title="变更差异"
        Width="1180"
        Height="760"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Height="30"
                        Margin="0,0,8,0"
                        Padding="8,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <RadioButton Content="完整文件"
                                     GroupName="DiffViewMode"
                                     VerticalAlignment="Center"
                                     Checked="FullDiffModeRadio_Checked"/>
                        <RadioButton Content="仅差异"
                                     GroupName="DiffViewMode"
                                     IsChecked="True"
                                     Margin="12,0,0,0"
                                     VerticalAlignment="Center"
                                     Checked="ChangedOnlyDiffModeRadio_Checked"/>
                    </StackPanel>
                </Border>
                <button:CButton Content="外部工具"
                                Width="82"
                                Height="30"
                                Margin="8,0,0,0"
                                Click="OpenExternalButton_Click"/>
                <button:CButton Content="复制路径"
                                Width="82"
                                Height="30"
                                Margin="8,0,0,0"
                                Click="CopyPathButton_Click"/>
                <button:CButton Content="打开文件夹"
                                Width="88"
                                Height="30"
                                Margin="8,0,0,0"
                                Click="OpenFolderButton_Click"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="{Binding TitleText}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="{Binding SummaryText}"
                           Margin="0,4,0,0"
                           Foreground="#6B7280"/>
                <TextBlock Text="{Binding TimingText}"
                           Margin="0,4,0,0"
                           Foreground="#8A6470"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="12,10,12,8"
                               LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="变更文件"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding FileCountText}"
                                   Foreground="#6B7280"/>
                    </DockPanel>

                    <TextBox Grid.Row="1"
                             Margin="12,0,12,8"
                             Height="28"
                             Padding="8,4"
                             Text="{Binding FileFilter, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="搜索变更文件"
                             VerticalContentAlignment="Center"/>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding ChangedFileView}"
                             SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Margin="12,10,12,4"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4B5563"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="8,4"
                                           ToolTip="{Binding ToolTip}">
                                    <Border DockPanel.Dock="Left"
                                            Width="22"
                                            Height="20"
                                            Margin="0,0,8,0"
                                            Background="{Binding StatusBrush}">
                                        <TextBlock Text="{Binding DisplayStatus}"
                                                   Foreground="#FFFFFF"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayPath}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#111827"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1">
                <Grid>
                    <diff:DiffViewer x:Name="DiffViewer"
                                     OldText="{Binding OldText}"
                                     NewText="{Binding NewText}"
                                     OldTextHeader="BASE"
                                     NewTextHeader="工作区"
                                     IsSideBySide="True"
                                     IgnoreUnchanged="{Binding IgnoreUnchanged}"
                                     Visibility="{Binding DiffViewerVisibility}"
                                     IsCommandBarVisible="False"
                                     HeaderBackground="#F3F5F8"
                                     HeaderForeground="#111827"
                                     InsertedBackground="#E7F6EA"
                                     DeletedBackground="#FCE8E6"
                                     UnchangedBackground="#FFFFFF"
                                     LineNumberForeground="#6B7280"/>
                    <Border Background="#FAFBFC"
                            Visibility="{Binding MessageVisibility}">
                        <TextBlock Text="{Binding MessageText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="#6B7280"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   MaxWidth="520"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
