<Window x:Class="PackageManager.Features.CodeWorkspace.Views.MergeToMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
        Title="合并回主干"
        Width="1040"
        Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <controls:CTextBlock Text="{Binding TitleText}" FontSize="20" FontWeight="SemiBold" Foreground="#111827"/>
                <controls:CTextBlock Text="{Binding HeaderDetail}" Margin="0,6,0,0" Foreground="#6B7280" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <controls:CTextBlock Text="目标分支" VerticalAlignment="Center" Foreground="#6B7280" Margin="0,0,8,0"/>
                <TextBox Width="120"
                         Height="28"
                         Text="{Binding TargetBranch, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEditTargetBranch}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Margin="0,14,0,12" Padding="12" Background="#FFFFFF" BorderBrush="#E3E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StepCheckText}" Foreground="{Binding StepCheckBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding StepFetchText}" Foreground="{Binding StepFetchBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding StepMergeText}" Foreground="{Binding StepMergeBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding StepResolveText}" Foreground="{Binding StepResolveBrush}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="{Binding StepPushText}" Foreground="{Binding StepPushBrush}" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E3E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="12,10">
                    <controls:CTextBlock Text="合并对象" FontWeight="SemiBold" Foreground="#374151"/>
                    <controls:CTextBlock Text="{Binding RepositorySummary}" Margin="10,0,0,0" Foreground="#8A94A3"/>
                </DockPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding MergeItems}"
                          SelectedItem="{Binding SelectedMergeItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          Background="#FFFFFF"
                          BorderThickness="0"
                          EnableRowVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="合并" Binding="{Binding IsSelected}" Width="52"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding TypeText}" Width="86" IsReadOnly="True"/>
                        <DataGridTextColumn Header="仓库" Binding="{Binding DisplayName}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="路径" Binding="{Binding PathText}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="源分支" Binding="{Binding SourceBranch}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="目标" Binding="{Binding TargetBranch}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="140" IsReadOnly="True"/>
                        <DataGridTextColumn Header="说明" Binding="{Binding DetailText}" Width="220" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Background="#FFFFFF" BorderBrush="#E3E8F0" BorderThickness="1">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <controls:CTextBlock Text="冲突文件" FontWeight="SemiBold" Foreground="#374151"/>
                    <controls:CTextBlock Text="{Binding ConflictSummary}" Margin="10,0,0,0" Foreground="#8A94A3"/>
                </StackPanel>
                <ListBox Grid.Row="1"
                         Margin="0,8,0,0"
                         ItemsSource="{Binding ConflictFiles}"
                         SelectedItem="{Binding SelectedConflictFile, Mode=TwoWay}"
                         DisplayMemberPath="RelativePath"/>

                <Grid Grid.Column="2" Grid.RowSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <button:CButton Content="AI 分析"
                                        Width="76"
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Click="AnalyzeConflictButton_Click"/>
                        <button:CButton Content="打开文件"
                                        Width="76"
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Click="OpenConflictFileButton_Click"/>
                        <button:CButton Content="打开文件夹"
                                        Width="88"
                                        Height="28"
                                        Click="OpenConflictFolderButton_Click"/>
                    </StackPanel>
                    <TextBox Grid.Row="1"
                             Margin="0,8,0,8"
                             Text="{Binding AiSuggestionText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"/>
                    <DockPanel Grid.Row="2">
                        <controls:CTextBlock Text="{Binding AiStatusText}" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <button:CButton Content="应用建议到文件"
                                        Width="118"
                                        Height="28"
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        Click="ApplySuggestionButton_Click"/>
                    </DockPanel>
                </Grid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="4" Margin="0,14,0,0">
            <controls:CTextBlock Text="{Binding StatusText}" Foreground="#6B7280" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <button:CButton Content="预检"
                                Width="64"
                                Height="30"
                                Margin="0,0,8,0"
                                Click="PrecheckButton_Click"/>
                <button:CButton Content="开始合并"
                                Width="86"
                                Height="30"
                                Margin="0,0,8,0"
                                Click="MergeButton_Click"/>
                <button:CButton Content="继续合并"
                                Width="86"
                                Height="30"
                                Margin="0,0,8,0"
                                Click="ContinueButton_Click"/>
                <button:CButton Content="终止合并"
                                Width="86"
                                Height="30"
                                Margin="0,0,8,0"
                                Click="AbortButton_Click"/>
                <button:CButton Content="推送 master"
                                Width="92"
                                Height="30"
                                Margin="0,0,8,0"
                                Click="PushButton_Click"/>
                <button:CButton Content="关闭"
                                Width="64"
                                Height="30"
                                Click="CloseButton_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
