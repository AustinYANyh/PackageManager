<Page x:Class="PackageManager.Features.CodeWorkspace.Views.CodeWorkspacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
      xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
      xmlns:dataGrid="clr-namespace:CustomControlLibrary.CustomControl.Controls.DataGrid;assembly=CustomControlLibrary"
      xmlns:navigation="clr-namespace:CustomControlLibrary.CustomControl.Controls.Navigation;assembly=CustomControlLibrary"
      Title="代码工作区"
      Background="#F7F8FA"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="代码工作区"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <button:CButton Content="{Binding RefreshButtonText}"
                                Width="92"
                                Height="30"
                                Margin="8,0,0,0"
                                IsEnabled="{Binding CanRefreshStatus}"
                                Click="RefreshStatusButton_Click"/>
                <button:CButton Content="管理仓库" Width="86" Height="30" Margin="8,0,0,0" Click="ManageRepositoriesButton_Click"/>
                <button:CButton Content="刷新项目文件" Width="104" Height="30" Margin="8,0,0,0" Click="RefreshProjectFilesButton_Click"/>
                <button:CButton Content="刷新列表" Width="80" Height="30" Margin="8,0,0,0" Click="ReloadButton_Click"/>
                <button:CButton Content="返回" Width="70" Height="30" Margin="8,0,0,0" Click="BackButton_Click"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="760"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="12,10,12,8"
                               LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="仓库列表"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding RepositoryCountText}"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <dataGrid:CDataGrid Grid.Row="1"
                              x:Name="RepositoryGrid"
                              ItemsSource="{Binding Repositories}"
                              SelectedItem="{Binding SelectedRepository, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserSortColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              Background="#FFFFFF"
                              BorderThickness="0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                        <dataGrid:CDataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <EventSetter Event="MouseDoubleClick" Handler="RepositoryRow_MouseDoubleClick"/>
                            </Style>
                        </dataGrid:CDataGrid.RowStyle>

                        <dataGrid:CDataGrid.Columns>
                            <DataGridTemplateColumn Header="仓库" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Margin="8,0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="状态" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Width="48" Height="28" ToolTip="{Binding VcsTooltip}">
                                            <Ellipse Width="18"
                                                     Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding VcsStatusBrush}"
                                                     Stroke="#FFFFFF"
                                                     StrokeThickness="2"/>
                                            <Rectangle Width="18"
                                                       Height="9"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,9,0,0"
                                                       Fill="{Binding SubRepositoryStatusBrush}">
                                                <Rectangle.OpacityMask>
                                                    <VisualBrush>
                                                        <VisualBrush.Visual>
                                                            <Ellipse Width="18" Height="18" Fill="Black"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                            <Border HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#D8DEE8"
                                                    BorderThickness="1"
                                                    Padding="2,0"
                                                    CornerRadius="2">
                                                <TextBlock Text="{Binding VcsTypeDisplay}"
                                                           Foreground="{Binding VcsTypeBrush}"
                                                           FontSize="9"
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="分支/版本" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BranchDisplay}"
                                                   Margin="6,0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding BranchDisplay}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="变更" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ChangesSummary}"
                                                   Margin="6,0"
                                                   Foreground="{Binding ChangesBrush}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding ChangesSummary}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="路径" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path}"
                                                   Margin="6,0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Path}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="操作" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <button:CButton Width="36"
                                                        Height="26"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        FontSize="18"
                                                        Content="⋯"
                                                        ToolTip="操作"
                                                        Click="ActionMenuButton_Click">
                                            <button:CButton.ContextMenu>
                                                <navigation:CContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <navigation:CMenuItem Header="Claude提交" Command="{Binding ClaudeCommitCommand}"/>
                                                    <navigation:CMenuItem Header="Codex提交" Command="{Binding CodexCommitCommand}"/>
                                                    <navigation:CMenuItem Header="拉取代码" Command="{Binding PullCommand}"/>
                                                    <Separator/>
                                                    <navigation:CMenuItem Header="VS" Command="{Binding OpenVSCommand}"/>
                                                    <navigation:CMenuItem Header="Rider" Command="{Binding OpenRiderCommand}"/>
                                                    <navigation:CMenuItem Header="Cursor" Command="{Binding OpenCursorCommand}"/>
                                                    <Separator/>
                                                    <navigation:CMenuItem Header="Claude" Command="{Binding OpenClaudeCommand}"/>
                                                    <navigation:CMenuItem Header="Codex" Command="{Binding OpenCodexCommand}"/>
                                                    <navigation:CMenuItem Header="文件夹" Command="{Binding OpenFolderCommand}"/>
                                                    <Separator/>
                                                    <navigation:CMenuItem Header="解除关联" Command="{Binding UnlinkPackageCommand}"/>
                                                </navigation:CContextMenu>
                                            </button:CButton.ContextMenu>
                                        </button:CButton>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </dataGrid:CDataGrid.Columns>
                    </dataGrid:CDataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1"
                    DataContext="{Binding SelectedRepository}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="14,12,14,10"
                               LastChildFill="True">
                        <button:CButton DockPanel.Dock="Right"
                                        Width="58"
                                        Height="26"
                                        Content="刷新"
                                        IsEnabled="{Binding HasSelectedRepository, RelativeSource={RelativeSource AncestorType=Page}}"
                                        Click="RefreshSelectedRepositoryButton_Click"/>
                        <StackPanel>
                            <TextBlock Text="详情"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock Text="{Binding Name, TargetNullValue=请选择仓库}"
                                       Margin="0,4,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Name}"/>
                            <TextBlock Text="{Binding VcsDetailTitle, TargetNullValue=未选择仓库}"
                                       Margin="0,3,0,0"
                                       Foreground="#6B7280"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding LastStatusRefreshText, TargetNullValue=尚未刷新}"
                                       Margin="0,3,0,0"
                                       Foreground="#6B7280"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="关联包:"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"/>
                                <Border Margin="6,0,0,0"
                                        Padding="6,2"
                                        Background="#EEF5FF"
                                        BorderBrush="#B8D4FF"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        ToolTip="{Binding LinkedPackageDisplay}"
                                        MouseLeftButtonDown="LinkedPackageBadge_MouseLeftButtonDown">
                                    <TextBlock Text="{Binding LinkedPackageDisplay, TargetNullValue=未关联产品包}"
                                               Foreground="#2563EB"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               TextDecorations="Underline"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="14,0"
                            Height="1"
                            Background="#E3E8F0"/>

                    <Grid Grid.Row="2" Margin="14,12,14,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                BorderBrush="{Binding GitAccentBrush}"
                                BorderThickness="{Binding GitAccentThickness}"
                                Padding="12"
                                Cursor="{Binding GitCursor}"
                                ToolTip="{Binding GitDiffHint}"
                                MouseLeftButtonDown="GitDetailCard_MouseLeftButtonDown">
                            <StackPanel>
                                <TextBlock Text="Git"
                                           FontWeight="SemiBold"
                                           Foreground="#346DDB"/>
                                <TextBlock Text="{Binding GitDetailLine, TargetNullValue=未选择仓库}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#374151"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                BorderBrush="{Binding SvnAccentBrush}"
                                BorderThickness="{Binding SvnAccentThickness}"
                                Padding="12"
                                Cursor="{Binding SvnCursor}"
                                ToolTip="{Binding SvnDiffHint}"
                                MouseLeftButtonDown="SvnDetailCard_MouseLeftButtonDown">
                            <StackPanel>
                                <TextBlock Text="SVN"
                                           FontWeight="SemiBold"
                                           Foreground="#7A52C7"/>
                                <TextBlock Text="{Binding SvnDetailLine, TargetNullValue=未选择仓库}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#374151"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="14,0,14,14"
                            BorderBrush="#E3E8F0"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0"
                                       Margin="12,10,12,8"
                                       LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding SubRepositoryPanelTitle, TargetNullValue=子仓库}"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding SubRepositoryDetail}"
                                           Foreground="#6B7280"/>
                            </DockPanel>

                            <TextBox Grid.Row="1"
                                     Margin="12,0,12,8"
                                     Height="28"
                                     Padding="8,4"
                                     Text="{Binding SubRepositoryFilter, RelativeSource={RelativeSource AncestorType=Page}, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="搜索子仓库"
                                     VerticalContentAlignment="Center"/>

                            <controls:CListView Grid.Row="2"
                                                ItemsSource="{Binding SubRepositoryView, RelativeSource={RelativeSource AncestorType=Page}}"
                                                BorderThickness="0"
                                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <controls:CListView.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="4,4,8,6"
                                                   Cursor="{Binding DetailCursor}"
                                                   ToolTip="{Binding DiffHint}"
                                                   MouseLeftButtonDown="SubRepositoryItem_MouseLeftButtonDown">
                                            <Ellipse DockPanel.Dock="Left"
                                                     Width="8"
                                                     Height="8"
                                                     Margin="0,7,8,0"
                                                     Fill="{Binding StatusBrush}"/>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Row="0"
                                                        Grid.Column="0"
                                                        Margin="0,0,6,0"
                                                        Padding="4,1"
                                                        BorderBrush="{Binding VcsTypeBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VcsTypeText}"
                                                               Foreground="{Binding VcsTypeBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="1"
                                                           Text="{Binding RelativePath}"
                                                           Foreground="#374151"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding RelativePath}"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="1"
                                                           Margin="0,2,0,0"
                                                           Text="{Binding DetailLine}"
                                                           Foreground="#6B7280"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding DetailLine}"/>
                                            </Grid>
                                        </DockPanel>
                                    </DataTemplate>
                                </controls:CListView.ItemTemplate>
                            </controls:CListView>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#F1F3F6"
                Padding="8,6">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#4B5563"/>
        </Border>
    </Grid>
</Page>
