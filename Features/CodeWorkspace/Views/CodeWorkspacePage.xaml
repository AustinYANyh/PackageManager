<Page x:Class="PackageManager.Features.CodeWorkspace.Views.CodeWorkspacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
      xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
      xmlns:dataGrid="clr-namespace:CustomControlLibrary.CustomControl.Controls.DataGrid;assembly=CustomControlLibrary"
      Title="代码工作区"
      Background="#F7F8FA"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded">
    <Page.Resources>
        <Style x:Key="ActionMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="12,6"/>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="代码工作区"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <button:CButton Content="{Binding RefreshButtonText}"
                                Width="92"
                                Height="30"
                                Margin="8,0,0,0"
                                IsEnabled="{Binding CanRefreshStatus}"
                                Click="RefreshStatusButton_Click"/>
                <button:CButton Content="管理仓库" Width="86" Height="30" Margin="8,0,0,0" Click="ManageRepositoriesButton_Click"/>
                <button:CButton Content="刷新项目文件" Width="104" Height="30" Margin="8,0,0,0" Click="RefreshProjectFilesButton_Click"/>
                <button:CButton Content="刷新列表" Width="80" Height="30" Margin="8,0,0,0" Click="ReloadButton_Click"/>
                <button:CButton Content="返回" Width="70" Height="30" Margin="8,0,0,0" Click="BackButton_Click"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="760"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="12,10,12,8"
                               LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="仓库列表"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding RepositoryCountText}"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <dataGrid:CDataGrid Grid.Row="1"
                              ItemsSource="{Binding Repositories}"
                              SelectedItem="{Binding SelectedRepository, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              Background="#FFFFFF"
                              BorderThickness="0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                        <dataGrid:CDataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="MinHeight" Value="68"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <EventSetter Event="MouseDoubleClick" Handler="RepositoryRow_MouseDoubleClick"/>
                            </Style>
                        </dataGrid:CDataGrid.RowStyle>

                        <dataGrid:CDataGrid.Columns>
                            <DataGridTemplateColumn Header="仓库" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,6" ToolTip="{Binding RepositoryListTooltip}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Row="0"
                                                  Grid.Column="0"
                                                  Grid.RowSpan="3"
                                                  Width="28"
                                                  Height="22"
                                                  Margin="0,0,7,0"
                                                  VerticalAlignment="Top"
                                                  ToolTip="{Binding VcsTooltip}">
                                                <Ellipse Width="15"
                                                         Height="15"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding VcsStatusBrush}"
                                                         Stroke="#FFFFFF"
                                                         StrokeThickness="2"/>
                                                <Rectangle Width="15"
                                                           Height="7"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="0,8,0,0"
                                                           Fill="{Binding SubRepositoryStatusBrush}">
                                                    <Rectangle.OpacityMask>
                                                        <VisualBrush>
                                                            <VisualBrush.Visual>
                                                                <Ellipse Width="15" Height="15" Fill="Black"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Rectangle.OpacityMask>
                                                </Rectangle>
                                                <Border HorizontalAlignment="Left"
                                                        VerticalAlignment="Bottom"
                                                        Background="#FFFFFF"
                                                        BorderBrush="#D8DEE8"
                                                        BorderThickness="1"
                                                        Padding="2,0">
                                                    <TextBlock Text="{Binding VcsTypeDisplay}"
                                                               Foreground="{Binding VcsTypeBrush}"
                                                               FontSize="8"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       Text="{Binding RepositoryPrimaryLine}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#111827"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="2"
                                                       Text="{Binding RepositoryRightSummary}"
                                                       Margin="12,0,0,0"
                                                       Foreground="{Binding ChangesBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ChangesSummary}"/>
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       Text="{Binding RepositorySecondaryLine}"
                                                       Margin="0,2,0,0"
                                                       Foreground="#4B5563"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       Text="{Binding RepositoryTertiaryLine}"
                                                       Margin="0,2,0,0"
                                                       Foreground="#6B7280"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="操作" Width="84">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <button:CButton Width="36"
                                                        Height="26"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        FontSize="18"
                                                        Content="⋯"
                                                        ToolTip="操作"
                                                        Click="ActionMenuButton_Click">
                                            <button:CButton.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="Claude提交" Command="{Binding ClaudeCommitCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <MenuItem Header="Codex提交" Command="{Binding CodexCommitCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <MenuItem Header="拉取代码" Command="{Binding PullCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <Separator/>
                                                    <MenuItem Header="VS" Command="{Binding OpenVSCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <MenuItem Header="Rider" Command="{Binding OpenRiderCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <MenuItem Header="Cursor" Command="{Binding OpenCursorCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Claude" Command="{Binding OpenClaudeCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <MenuItem Header="Codex" Command="{Binding OpenCodexCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                    <MenuItem Header="文件夹" Command="{Binding OpenFolderCommand}" Style="{StaticResource ActionMenuItemStyle}"/>
                                                </ContextMenu>
                                            </button:CButton.ContextMenu>
                                        </button:CButton>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </dataGrid:CDataGrid.Columns>
                    </dataGrid:CDataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1"
                    DataContext="{Binding SelectedRepository}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="14,12,14,10"
                               LastChildFill="True"
                               Cursor="{Binding DetailCursor}"
                               ToolTip="{Binding DiffHint}"
                               MouseLeftButtonDown="RepositoryDetailHeader_MouseLeftButtonDown">
                        <button:CButton DockPanel.Dock="Right"
                                        Width="58"
                                        Height="26"
                                        Content="刷新"
                                        IsEnabled="{Binding HasSelectedRepository, RelativeSource={RelativeSource AncestorType=Page}}"
                                        Click="RefreshSelectedRepositoryButton_Click"/>
                        <StackPanel>
                            <TextBlock Text="详情"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock Text="{Binding Name, TargetNullValue=请选择仓库}"
                                       Margin="0,4,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Name}"/>
                            <TextBlock Text="{Binding VcsDetailTitle, TargetNullValue=未选择仓库}"
                                       Margin="0,3,0,0"
                                       Foreground="#6B7280"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding LastStatusRefreshText, TargetNullValue=尚未刷新}"
                                       Margin="0,3,0,0"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="14,0"
                            Height="1"
                            Background="#E3E8F0"/>

                    <Grid Grid.Row="2" Margin="14,12,14,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                BorderBrush="#D8DEE8"
                                BorderThickness="1"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="版本控制概览"
                                           Grid.Row="0"
                                           Grid.ColumnSpan="2"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Git"
                                           Margin="0,8,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#346DDB"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding GitCompactLine}"
                                           Margin="0,8,0,0"
                                           Foreground="#374151"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding GitCompactLine}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="SVN"
                                           Margin="0,5,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#7A52C7"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding SvnCompactLine}"
                                           Margin="0,5,0,0"
                                           Foreground="#374151"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding SvnCompactLine}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="14,0,14,14"
                            BorderBrush="#E3E8F0"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0"
                                       Margin="12,10,12,8"
                                       LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding SubRepositoryPanelTitle, TargetNullValue=子仓库}"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding SubRepositoryDetail}"
                                           Foreground="#6B7280"/>
                            </DockPanel>

                            <TextBox Grid.Row="1"
                                     Margin="12,0,12,8"
                                     Height="28"
                                     Padding="8,4"
                                     Text="{Binding SubRepositoryFilter, RelativeSource={RelativeSource AncestorType=Page}, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="搜索子仓库"
                                     VerticalContentAlignment="Center"/>

                            <controls:CListView Grid.Row="2"
                                                ItemsSource="{Binding SubRepositoryView, RelativeSource={RelativeSource AncestorType=Page}}"
                                                BorderThickness="0"
                                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <controls:CListView.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListViewItem}">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </controls:CListView.ItemContainerStyle>
                                <controls:CListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,5,8,6"
                                              Cursor="{Binding DetailCursor}"
                                              ToolTip="{Binding FullTooltip}"
                                              MouseLeftButtonDown="SubRepositoryItem_MouseLeftButtonDown">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0"
                                                     Width="8"
                                                     Height="8"
                                                     Margin="0,6,8,0"
                                                     VerticalAlignment="Top"
                                                     Fill="{Binding StatusBrush}"/>
                                            <Grid Grid.Column="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Row="0"
                                                        Grid.Column="0"
                                                        Margin="0,0,6,0"
                                                        Padding="4,1"
                                                        BorderBrush="{Binding VcsTypeBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VcsTypeText}"
                                                               Foreground="{Binding VcsTypeBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="1"
                                                           Text="{Binding DisplayName}"
                                                           Foreground="#374151"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding DisplayName}"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="0"
                                                           Grid.ColumnSpan="2"
                                                           Margin="0,3,0,0"
                                                           Text="{Binding CompactLine}"
                                                           Foreground="#6B7280"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="34"
                                                           ToolTip="{Binding CompactLine}"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </controls:CListView.ItemTemplate>
                            </controls:CListView>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#F1F3F6"
                Padding="8,6">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#4B5563"/>
        </Border>
    </Grid>
</Page>
