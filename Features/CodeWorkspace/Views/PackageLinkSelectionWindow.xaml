<Window x:Class="PackageManager.Features.CodeWorkspace.Views.PackageLinkSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
        Title="关联产品包"
        Width="680"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F8FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <controls:CTextBlock Text="{Binding TitleText}" FontSize="20" FontWeight="SemiBold" Foreground="#111827"/>
            <controls:CTextBlock Text="{Binding RepositoryText}" Margin="0,6,0,0" Foreground="#6B7280" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="14"
                Background="#FFFFFF"
                BorderBrush="#E3E8F0"
                BorderThickness="1">
            <StackPanel>
                <controls:CTextBlock Text="{Binding SelectorTitle}"
                                      FontWeight="SemiBold"
                                      Foreground="#374151"
                                      HorizontalAlignment="Left"
                                      TextAlignment="Left"/>
                <controls:CComboBox Margin="0,8,0,0"
                                    Height="30"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    ItemsSource="{Binding SelectionOptions}"
                                    SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                    DisplayMemberPath="DisplayName"
                                    IsTextSearchEnabled="True"/>
                <controls:CTextBlock Text="{Binding SuggestionText}"
                                      Margin="0,8,0,0"
                                      Foreground="#6B7280"
                                      TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <controls:CTextBlock Grid.Row="2"
                             Text="关联关系会保存到代码仓库配置，不会修改产品包配置。"
                             Margin="0,12,0,0"
                             Foreground="#8A94A3"
                             VerticalAlignment="Top"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <button:CButton Content="确认关联"
                            Width="92"
                            Height="30"
                            Margin="0,0,8,0"
                            Click="ConfirmButton_Click"/>
            <button:CButton Content="取消"
                            Width="76"
                            Height="30"
                            Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
