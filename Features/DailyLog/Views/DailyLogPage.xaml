<Page x:Class="PackageManager.Features.DailyLog.Views.DailyLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
      Title="工作日报">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="工作日报" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
        </StackPanel>

        <!-- 控制栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="日期:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <DatePicker Grid.Column="1" x:Name="DatePick" Width="160" Height="30"
                        VerticalAlignment="Center" />

            <button:CButton Grid.Column="2" Content="生成日报" Width="100" Height="32"
                                  Margin="16,0,0,0" Click="Generate_Click"
                                  Background="#2B7FFF" Foreground="White" />

            <button:CButton Grid.Column="3" Content="复制到剪贴板" Width="120" Height="32"
                            Margin="8,0,0,0" Click="Copy_Click"
                            Background="#10B981" Foreground="White" />

            <TextBlock Grid.Column="4" x:Name="StatusText" Text="就绪"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Foreground="#6B7280" FontSize="12" />
        </Grid>

        <!-- 可编辑日志区域 -->
        <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                Background="White">
            <TextBox x:Name="LogTextBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontSize="14"
                     FontFamily="Consolas, Microsoft YaHei"
                     Padding="16"
                     BorderThickness="0"
                     IsReadOnly="False"
                     Text="" />
        </Border>

        <!-- 底部提示 -->
        <TextBlock Grid.Row="3" Text="提示: 可直接编辑上方日志内容，确认后点击「复制到剪贴板」粘贴到钉钉"
                   Foreground="#9CA3AF" FontSize="12" Margin="0,8,0,0" />
    </Grid>
</Page>
