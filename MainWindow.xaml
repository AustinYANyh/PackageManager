<Window x:Class="PackageManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PackageManager"
        xmlns:C="clr-namespace:CustomControlLibrary.CustomControl.Controls.DataGrid;assembly=CustomControlLibrary"
        xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        xmlns:views="clr-namespace:PackageManager.Views"
        xmlns:notif="clr-namespace:PackageManager.Features.Notifications.Views"
        mc:Ignorable="d"
        Title="DevKit" Height="890" Width="1500" MinWidth="960"
        Icon="/Assets/Icons/App.ico"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen" AllowDrop="True">
    <Window.Resources>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:CTextBlock Grid.Column="0" Text="DevKit" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />

            <!-- 返回仪表盘按钮：非首页时显示 -->
            <Border x:Name="BackToDashboardButton" Grid.Column="1"
                    Margin="16,0,0,0" Padding="10,5"
                    Background="#08000000"
                    BorderBrush="#15000000"
                    BorderThickness="1"
                    CornerRadius="6"
                    Cursor="Hand"
                    MouseLeftButtonUp="BackToDashboardButton_Click"
                    Visibility="Collapsed">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#10000000"/>
                                <Setter Property="BorderBrush" Value="#25000000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#2B7FFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <controls:CTextBlock Text="仪表盘" FontSize="13" VerticalAlignment="Center" Foreground="#333333"/>
                </StackPanel>
            </Border>

            <TextBox Grid.Column="2" x:Name="SearchBox" Height="28" Margin="16,0,0,0" Visibility="Hidden" />
            <StackPanel x:Name="PackageToolbar" Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                <button:CButton Content="刷新" Margin="0,0,8,0" Padding="10,6" Click="RefreshButton_Click" />

                <!-- 常用网址导航 -->
                <controls:CComboBox x:Name="CommonLinksCombo"
                                    Width="220"
                                    Height="30"
                                    Margin="12,0,0,0"
                                    ItemsSource="{Binding CommonLinks}"
                                    DisplayMemberPath="Name"
                                    SelectedItem="{Binding SelectedCommonLink, Mode=TwoWay}" />
                <button:CButton Content="打开" Margin="8,0,0,0" Padding="10,6" Click="OpenSelectedLinkButton_Click" />
            </StackPanel>

            <!-- 通知铃铛 -->
            <Grid x:Name="NotificationBell" Grid.Column="4" Margin="12,0,0,0"
                  Cursor="Hand" VerticalAlignment="Center"
                  MouseLeftButtonUp="NotificationBell_Click">
                <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="#555555" VerticalAlignment="Center"/>
                <!-- 未读徽章 -->
                <Border x:Name="UnreadBadge"
                        Background="#E81123" CornerRadius="8"
                        MinWidth="16" Height="16"
                        Padding="3,0" Margin="10,-10,-6,0"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock x:Name="UnreadCountText" Text="0"
                               FontSize="10" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- 通知面板 Popup -->
            <Popup x:Name="NotificationPopup"
                   PlacementTarget="{Binding ElementName=NotificationBell}"
                   Placement="Bottom" StaysOpen="False"
                   HorizontalOffset="-330" VerticalOffset="8"
                   AllowsTransparency="True">
                <notif:NotificationPanel x:Name="NotificationPanelControl"/>
            </Popup>
        </Grid>

        <!-- 中央内容区：全宽使用 -->
        <Frame x:Name="CentralFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Background="Transparent" />

        <StatusBar Grid.Row="2" Margin="0,12,0,0">
            <StatusBarItem>
                <controls:CTextBlock Text="{Binding LatestActivePackage.StatusText, FallbackValue=就绪, TargetNullValue=就绪}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
