<Window x:Class="MftScanner.RevitFileCleanupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dataGrid="clr-namespace:CustomControlLibrary.CustomControl.Controls.DataGrid;assembly=CustomControlLibrary"
        Title="清理RVT / RFA（管理员）"
        Height="760"
        Width="1220"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="清理 RVT / RFA 文件" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="使用 MFT 高速扫描（管理员权限），支持自定义目录、单个删除和一键全部删除。"
                       Margin="0,6,0,0" Foreground="#6B7280"/>
        </StackPanel>

        <Border Grid.Row="1" Padding="14" BorderThickness="1"
                BorderBrush="#1F000000" Background="#06000000" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="默认扫描目录" FontSize="14" FontWeight="SemiBold"/>
                    <WrapPanel Margin="0,10,0,0">
                        <CheckBox Content="桌面" IsChecked="{Binding ScanDesktop}" Margin="0,0,18,8"/>
                        <CheckBox Content="下载" IsChecked="{Binding ScanDownloads}" Margin="0,0,18,8"/>
                        <CheckBox Content="文档" IsChecked="{Binding ScanDocuments}" Margin="0,0,18,8"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding ScanScopeText}" Margin="0,10,0,0"
                               Foreground="#6B7280" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="开始扫描" Width="110" Padding="6,4"
                                Click="ScanButton_Click" IsEnabled="{Binding CanScan}"/>
                        <Button Content="一键全部删除" Width="110" Margin="8,0,0,0" Padding="6,4"
                                Click="DeleteAllButton_Click" IsEnabled="{Binding CanDeleteAll}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="自定义扫描目录" FontSize="14" FontWeight="SemiBold"/>
                    <Border Margin="0,10,0,0" BorderThickness="1" BorderBrush="#14000000"
                            Background="#04FFFFFF" CornerRadius="4" Height="120">
                        <Grid>
                            <ListBox ItemsSource="{Binding CustomDirectories}"
                                     SelectedItem="{Binding SelectedCustomDirectory}"
                                     BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Padding="4,3"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="尚未添加自定义目录"
                                       Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CustomDirectories.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="添加目录" Width="100" Padding="6,4"
                                Click="AddDirectoryButton_Click" IsEnabled="{Binding CanScan}"/>
                        <Button Content="移除所选" Width="100" Margin="8,0,0,0" Padding="6,4"
                                Click="RemoveDirectoryButton_Click" IsEnabled="{Binding CanEditCustomDirectories}"/>
                        <Button Content="清空自定义" Width="110" Margin="8,0,0,0" Padding="6,4"
                                Click="ClearDirectoriesButton_Click" IsEnabled="{Binding CanClearCustomDirectories}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="{Binding SummaryText}" VerticalAlignment="Center" Foreground="#374151"/>
                <ProgressBar Width="180" Height="16" Margin="12,0,0,0"
                             IsIndeterminate="True"
                             Visibility="{Binding BusyVisibility}"
                             VerticalAlignment="Center"/>
            </DockPanel>

            <dataGrid:CDataGrid x:Name="FilesGrid"
                         Grid.Row="1"
                         ItemsSource="{Binding Files}"
                         TextAlignment="Left"
                         EnableAutoTemplateSelection="True"
                         Margin="0"/>
            <!-- <DataGrid Grid.Row="1" x:Name="FilesGrid" -->
            <!--           AutoGenerateColumns="False" -->
            <!--           IsReadOnly="True" -->
            <!--           CanUserAddRows="False" -->
            <!--           CanUserDeleteRows="False" -->
            <!--           SelectionMode="Extended" -->
            <!--           GridLinesVisibility="Horizontal" -->
            <!--           HeadersVisibility="Column" -->
            <!--           ItemsSource="{Binding Files}" -->
            <!--           BorderBrush="#1F000000" BorderThickness="1" -->
            <!--           Background="#08000000"> -->
            <!--     <DataGrid.Columns> -->
            <!--         <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="220"/> -->
            <!--         <DataGridTextColumn Header="来源" Binding="{Binding SourceDisplayName}" Width="100"/> -->
            <!--         <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="120"/> -->
            <!--         <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedText}" Width="170"/> -->
            <!--         <DataGridTextColumn Header="目录" Binding="{Binding DirectoryPath}" Width="*"/> -->
            <!--         <DataGridTemplateColumn Header="操作" Width="100"> -->
            <!--             <DataGridTemplateColumn.CellTemplate> -->
            <!--                 <DataTemplate> -->
            <!--                     <Button Content="删除" Padding="8,2" -->
            <!--                             Command="{Binding DeleteCommand}"/> -->
            <!--                 </DataTemplate> -->
            <!--             </DataGridTemplateColumn.CellTemplate> -->
            <!--         </DataGridTemplateColumn> -->
            <!--     </DataGrid.Columns> -->
            <!-- </DataGrid> -->
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="关闭" Width="100" Padding="6,4" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
