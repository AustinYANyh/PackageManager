<Window x:Class="MftScanner.EverythingSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dataGrid="clr-namespace:CustomControlLibrary.CustomControl.Controls.DataGrid;assembly=CustomControlLibrary"
        Title="文件搜索（管理员）"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Loaded="EverythingSearchWindow_Loaded"
        Closed="EverythingSearchWindow_Closed">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 搜索框 -->
        <Border Grid.Row="0" Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="#1F000000">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         FontSize="16"
                         Height="34"
                         Padding="8,4"
                         VerticalContentAlignment="Center"
                         BorderThickness="1"
                         BorderBrush="#CCCCCC"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"/>
                <Button x:Name="ForceRescanButton"
                        Grid.Column="1"
                        Content="重建索引"
                        Width="90" Height="34"
                        Margin="8,0,0,0"
                        Click="ForceRescanButton_Click"/>
            </Grid>
        </Border>

        <!-- 结果列表 -->
        <dataGrid:CDataGrid x:Name="ResultsGrid"
                            Grid.Row="1"
                            TextAlignment="Left"
                            IsReadOnly="True"
                            EnableAutoTemplateSelection="True"
                            MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                            SelectionChanged="ResultsGrid_SelectionChanged">
            <dataGrid:CDataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="打开所在位置" Click="OpenContainingFolder_Click"/>
                    <MenuItem Header="复制路径" Click="CopyPath_Click"/>
                </ContextMenu>
            </dataGrid:CDataGrid.ContextMenu>
        </dataGrid:CDataGrid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="IndexingProgress"
                             Width="160" Height="14"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
