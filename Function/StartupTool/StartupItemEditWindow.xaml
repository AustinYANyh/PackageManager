<Window x:Class="PackageManager.Function.StartupTool.StartupItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
        Title="编辑启动项"
        Height="280" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 名称 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <controls:CTextBlock Grid.Column="0" Text="名称" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="NameBox" Grid.Column="1" Height="30"
                     VerticalContentAlignment="Center" Padding="8,0"
                     FontSize="13" BorderBrush="#CCCCCC"/>
        </Grid>

        <!-- 路径 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <controls:CTextBlock Grid.Column="0" Text="路径" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="PathBox" Grid.Column="1" Height="30"
                     VerticalContentAlignment="Center" Padding="8,0"
                     FontSize="12" BorderBrush="#CCCCCC"/>
            <button:CButton Grid.Column="3" Content="浏览" Width="56" Height="30"
                            Click="BrowseButton_Click"/>
        </Grid>

        <!-- 参数 -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <controls:CTextBlock Grid.Column="0" Text="参数" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="ArgsBox" Grid.Column="1" Height="30"
                     VerticalContentAlignment="Center" Padding="8,0"
                     FontSize="13" BorderBrush="#CCCCCC"/>
        </Grid>

        <!-- 备注 -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <controls:CTextBlock Grid.Column="0" Text="备注" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="NoteBox" Grid.Column="1" Height="30"
                     VerticalContentAlignment="Center" Padding="8,0"
                     FontSize="13" BorderBrush="#CCCCCC"/>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <button:CButton Content="确定" Width="72" Margin="0,0,8,0"
                            Click="OkButton_Click"/>
            <button:CButton Content="取消" Width="72"
                            Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
