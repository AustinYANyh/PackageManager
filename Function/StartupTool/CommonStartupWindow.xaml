<Window x:Class="PackageManager.Function.StartupTool.CommonStartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        xmlns:local="clr-namespace:PackageManager.Function.StartupTool"
        Title="常用启动项工作台"
        Height="860"
        Width="1860"
        MinHeight="720"
        MinWidth="1480"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Closed="Window_Closed"
        Background="#F4F0E9">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowTextBrush" Color="#1D2620" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#69746D" />
        <SolidColorBrush x:Key="LineBrush" Color="#1A2D201A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FDFDFC" />
        <SolidColorBrush x:Key="SoftPanelBrush" Color="#F6F7F4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#1A6A5F" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#DCEFE8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#A14848" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#F6DADA" />
        <SolidColorBrush x:Key="GoldBrush" Color="#8B6A1B" />
        <SolidColorBrush x:Key="GoldSoftBrush" Color="#F5EBC8" />

        <Style x:Key="ToolbarGhostButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Foreground" Value="{StaticResource WindowTextBrush}" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF6FAF7" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarGhostButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#154F47" />
                    <Setter Property="BorderBrush" Value="#154F47" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarGhostButtonStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="1,0" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TagBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="#FFEDF1EE" />
        </Style>

        <Style x:Key="MenuListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RootBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12,10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFE5F0EA" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#FFBFD8CF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFF5F8F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CandidateListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CandidateItemBorder"
                                Background="#FFF8FAF7"
                                BorderBrush="#FFE4E9E4"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CandidateItemBorder" Property="Background" Value="#FFF3F9F6" />
                                <Setter TargetName="CandidateItemBorder" Property="BorderBrush" Value="#FFBFD8CF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CandidateItemBorder" Property="Background" Value="#FFF0F8F4" />
                                <Setter TargetName="CandidateItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Width" Value="0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="0" Height="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF7F3ED" Offset="0" />
                <GradientStop Color="#FFEEF3EF" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Margin="18"
                CornerRadius="30"
                BorderBrush="#AAFFFFFF"
                BorderThickness="1"
                Background="#CCFFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Border Padding="18,16"
                            Background="#BFFFFFFF"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="30,30,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="14,12"
                                        CornerRadius="18"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        Background="#FFF8F9F5"
                                        Cursor="IBeam"
                                        PreviewMouseLeftButtonDown="SearchArea_PreviewMouseLeftButtonDown">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🔎"
                                                   FontSize="15"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0" />
                                         <TextBox x:Name="SearchBox"
                                                  Grid.Column="1"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  FontSize="14"
                                                  VerticalContentAlignment="Center"
                                                  TextChanged="SearchBox_TextChanged"
                                                  KeyDown="SearchBox_KeyDown"
                                                  ToolTip="搜索已有启动项；本人账号还会联动文件搜索候选" />
                                    </Grid>
                                </Border>

                                <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                                    <Button x:Name="AllViewButton"
                                            Content="全部启动项"
                                            Click="AllViewButton_Click"
                                            Style="{StaticResource ToolbarGhostButtonStyle}" />
                                    <Button x:Name="RecentViewButton"
                                            Content="最近启动"
                                            Click="RecentViewButton_Click"
                                            Style="{StaticResource ToolbarGhostButtonStyle}" />
                                    <Button x:Name="FavoriteViewButton"
                                            Content="收藏"
                                            Click="FavoriteViewButton_Click"
                                            Style="{StaticResource ToolbarGhostButtonStyle}" />
                                    <Button x:Name="BrokenViewButton"
                                            Content="失效项"
                                            Click="BrokenViewButton_Click"
                                            Style="{StaticResource ToolbarGhostButtonStyle}" />
                                </WrapPanel>
                            </Grid>

                            <WrapPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                <button:CButton Content="批量管理"
                                                Width="82"
                                                Height="42"
                                                IsEnabled="False"
                                                ToolTip="管理视图后续补齐" />
                                <button:CButton Content="手动添加"
                                                Width="82"
                                                Height="42"
                                                Margin="8,0,0,0"
                                                Click="ManualAddButton_Click" />
                                <button:CButton Content="新建分组"
                                                Width="82"
                                                Height="42"
                                                Margin="8,0,0,0"
                                                Click="ShowNewGroupPanelButton_Click" />
                                <button:CButton Content="重建索引"
                                                Width="82"
                                                Height="42"
                                                Margin="8,0,0,0"
                                                Click="ScanButton_Click" />
                                <button:CButton x:Name="StopButton"
                                                Content="停止"
                                                Width="72"
                                                Height="42"
                                                Margin="8,0,0,0"
                                                Click="StopButton_Click"
                                                IsEnabled="False" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="NewGroupPanel"
                            Padding="18,14"
                            Background="#EFFFFFFF"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Visibility="Collapsed">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="新建分组"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,12,0" />
                            <TextBox x:Name="NewGroupNameBox"
                                     Width="240"
                                     Height="34"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,10,0"
                                     KeyDown="NewGroupNameBox_KeyDown" />
                            <Button Content="创建"
                                    Style="{StaticResource ToolbarPrimaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="CreateGroupButton_Click" />
                            <Button Content="取消"
                                    Style="{StaticResource ToolbarGhostButtonStyle}"
                                    Margin="0"
                                    Click="CancelNewGroupButton_Click" />
                        </WrapPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1" Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="500" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer x:Name="LeftSidebarScrollViewer"
                                  Grid.Column="0"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  CanContentScroll="False">
                        <StackPanel Width="{Binding ElementName=LeftSidebarScrollViewer, Path=ViewportWidth}">
                            <Border Padding="18"
                                    CornerRadius="22"
                                    Background="#FF1E655C"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Launcher Desk"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="把常用启动项从维护列表升级成真实工作起点。收藏、最近、失效项和搜索候选，都聚合到同一个工作台。"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               Foreground="#E8FFFFFF" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="工作区视图"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="4,0,0,8" />
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="8"
                                    Margin="0,0,0,14">
                                <ListBox x:Name="ViewList"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         PreviewMouseLeftButtonDown="ViewList_PreviewMouseLeftButtonDown"
                                         PreviewMouseWheel="LeftSidebarList_PreviewMouseWheel"
                                         SelectionChanged="ViewList_SelectionChanged"
                                         ItemContainerStyle="{StaticResource MenuListItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:StartupNavigationItemVm}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource WindowTextBrush}" />
                                                <Border Grid.Column="1"
                                                        CornerRadius="999"
                                                        Padding="8,3"
                                                        Background="{Binding CountBackground}">
                                                    <TextBlock Text="{Binding Count}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding CountForeground}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <TextBlock Text="分组导航"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="4,0,0,8" />
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="8"
                                    Margin="0,0,0,14">
                                <ListBox x:Name="GroupList"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         PreviewMouseLeftButtonDown="GroupList_PreviewMouseLeftButtonDown"
                                         PreviewMouseWheel="LeftSidebarList_PreviewMouseWheel"
                                         SelectionChanged="GroupList_SelectionChanged"
                                         ItemContainerStyle="{StaticResource MenuListItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:StartupNavigationItemVm}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource WindowTextBrush}" />
                                                <Border Grid.Column="1"
                                                        CornerRadius="999"
                                                        Padding="8,3"
                                                        Background="{Binding CountBackground}">
                                                    <TextBlock Text="{Binding Count}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding CountForeground}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <TextBlock Text="工作台摘要"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="4,0,0,8" />
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="12"
                                    Margin="0,0,0,14">
                                <UniformGrid Columns="2">
                                    <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="12" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock x:Name="SidebarTotalItemsText" Text="0" FontSize="24" FontWeight="SemiBold" />
                                            <TextBlock Text="总条目" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock x:Name="SidebarFavoriteItemsText" Text="0" FontSize="24" FontWeight="SemiBold" />
                                            <TextBlock Text="收藏" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="12" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock x:Name="SidebarBrokenItemsText" Text="0" FontSize="24" FontWeight="SemiBold" />
                                            <TextBlock Text="路径异常" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="12">
                                        <StackPanel>
                                            <TextBlock x:Name="SidebarGroupCountText" Text="0" FontSize="24" FontWeight="SemiBold" />
                                            <TextBlock Text="分组数" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Border>

                            <TextBlock Text="待处理队列"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="4,0,0,8" />
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="14">
                                <StackPanel>
                                    <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock x:Name="QueueBrokenTitleText" Text="0 个失效项待修复" FontWeight="SemiBold" />
                                            <TextBlock x:Name="QueueBrokenHintText" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="12">
                                        <StackPanel>
                                            <TextBlock x:Name="QueueCandidateTitleText" Text="0 个搜索候选待加入" FontWeight="SemiBold" />
                                            <TextBlock x:Name="QueueCandidateHintText" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="WorkbenchScrollViewer"
                                  Grid.Column="2"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  CanContentScroll="False">
                        <StackPanel Width="{Binding ElementName=WorkbenchScrollViewer, Path=ViewportWidth}">
                            <Grid Margin="0,2,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="WorkbenchTitleText"
                                               Text="工作台"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource WindowTextBrush}" />
                                    <TextBlock x:Name="WorkbenchSubtitleText"
                                               Margin="0,6,0,0"
                                               FontSize="13"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="当前视图："
                                               FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="CurrentViewBadgeText"
                                               Margin="4,0,12,0"
                                               Text="全部启动项"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="当前分组："
                                               FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="CurrentGroupBadgeText"
                                               Margin="4,0,0,0"
                                               Text="全部分组"
                                               Foreground="{StaticResource WindowTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="18" Padding="16">
                                    <StackPanel>
                                        <TextBlock x:Name="PrimarySummaryText" Text="0" FontSize="28" FontWeight="SemiBold" />
                                        <TextBlock x:Name="PrimarySummaryLabel" Text="当前条目" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="18" Padding="16">
                                    <StackPanel>
                                        <TextBlock x:Name="SecondarySummaryText" Text="0" FontSize="28" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SecondarySummaryLabel" Text="收藏" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="18" Padding="16">
                                    <StackPanel>
                                        <TextBlock x:Name="TertiarySummaryText" Text="0" FontSize="28" FontWeight="SemiBold" />
                                        <TextBlock x:Name="TertiarySummaryLabel" Text="最近启动" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="6" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="18" Padding="16">
                                    <StackPanel>
                                        <TextBlock x:Name="QuaternarySummaryText" Text="0" FontSize="28" FontWeight="SemiBold" />
                                        <TextBlock x:Name="QuaternarySummaryLabel" Text="状态异常" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border x:Name="FeaturedSection"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="16"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="FeaturedSectionTitleText" Text="置顶与收藏" FontSize="17" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FeaturedSectionHintText" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="FeaturedBadgeText"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Text="0 个收藏入口"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource GoldBrush}" />
                                    </Grid>
                                    <ItemsControl x:Name="FeaturedItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel IsItemsHost="True" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:StartupItemVm}">
                                                <Border Width="280"
                                                        Margin="0,0,10,12"
                                                        Padding="13"
                                                        CornerRadius="22"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="White" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                    <Setter Property="Background" Value="#FFF7FCFA" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsBroken}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#FFD8A9A9" />
                                                                    <Setter Property="Background" Value="#FFFFFBFB" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid Tag="{Binding}" Background="Transparent" MouseLeftButtonUp="StartupCard_MouseLeftButtonUp" MouseLeftButtonDown="StartupCard_MouseLeftButtonDown">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="46" Height="46" CornerRadius="14" Background="{Binding AccentBrush}" Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding InitialLetter}" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Margin="0,4,0,0" Text="{Binding PathCompactDisplay}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2"
                                                                       Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Text="{Binding StatusLabel}"
                                                                       Foreground="{Binding StatusForeground}"
                                                                       FontSize="11"
                                                                       FontWeight="Bold" />
                                                            </Grid>

                                                        <WrapPanel Grid.Row="1" Margin="0,12,0,8">
                                                            <TextBlock Margin="0,0,12,6" Text="{Binding GroupName}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" />
                                                            <TextBlock Margin="0,0,12,6" Text="{Binding TypeLabel}" Foreground="{StaticResource WindowTextBrush}" FontSize="11" FontWeight="Bold" />
                                                            <TextBlock Margin="0,0,12,6" Text="收藏" Foreground="{StaticResource GoldBrush}" FontSize="11" FontWeight="Bold" Visibility="{Binding FavoriteVisibility}" />
                                                            <TextBlock Margin="0,0,12,6" Text="路径异常" Foreground="{StaticResource DangerBrush}" FontSize="11" FontWeight="Bold" Visibility="{Binding BrokenVisibility}" />
                                                        </WrapPanel>

                                                        <Border Grid.Row="2" Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="10" Margin="0,0,0,10">
                                                            <StackPanel>
                                                                <TextBlock Text="备注" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBlock Text="{Binding NoteSummaryText}" Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource WindowTextBrush}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Grid.Row="3" Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="10" Margin="0,0,0,10">
                                                            <StackPanel>
                                                                <TextBlock Text="启动参数" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBlock Text="{Binding ArgumentsSummaryText}" Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource WindowTextBrush}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <WrapPanel Grid.Row="4" Margin="0,0,0,12">
                                                            <Border Style="{StaticResource TagBadgeStyle}" Background="{StaticResource SoftPanelBrush}" Padding="10,6">
                                                                <TextBlock Text="{Binding LastLaunchInlineText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                            </Border>
                                                            <Border Style="{StaticResource TagBadgeStyle}" Background="{StaticResource SoftPanelBrush}" Padding="10,6">
                                                                <TextBlock Text="{Binding LaunchCountInlineText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                            </Border>
                                                        </WrapPanel>

                                                        <Grid Grid.Row="5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0" Content="启动" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="LaunchItemButton_Click" />
                                                            <Button Grid.Column="2" Content="目录" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="OpenFolderItemButton_Click" />
                                                            <Button Grid.Column="4" Content="编辑" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="EditItemButton_Click" />
                                                            <Button Grid.Column="6" Content="路径" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="CopyItemPathButton_Click" />
                                                            <Button Grid.Column="8" Content="{Binding FavoriteButtonCompactText}" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="ToggleFavoriteButton_Click" />
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="WorkspaceSectionTitleText" Text="当前工作区条目" FontSize="17" FontWeight="SemiBold" />
                                            <TextBlock x:Name="WorkspaceSectionHintText" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource TagBadgeStyle}" Background="#FFE5F0EA" Margin="0">
                                            <TextBlock x:Name="WorkspaceBadgeText" Text="0 个条目" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                        </Border>
                                    </Grid>

                                    <TextBlock x:Name="WorkspaceEmptyText"
                                               Text="当前筛选下没有条目。"
                                               FontSize="13"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,0,0,12"
                                               Visibility="Collapsed" />

                                    <ItemsControl x:Name="WorkspaceItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel IsItemsHost="True" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:StartupItemVm}">
                                                <Border Width="280"
                                                        Margin="0,0,10,12"
                                                        Padding="13"
                                                        CornerRadius="22"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="White" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                    <Setter Property="Background" Value="#FFF7FCFA" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsBroken}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#FFD8A9A9" />
                                                                    <Setter Property="Background" Value="#FFFFFBFB" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid Tag="{Binding}" Background="Transparent" MouseLeftButtonUp="StartupCard_MouseLeftButtonUp" MouseLeftButtonDown="StartupCard_MouseLeftButtonDown">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="46" Height="46" CornerRadius="14" Background="{Binding AccentBrush}" Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding InitialLetter}" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Margin="0,4,0,0" Text="{Binding PathCompactDisplay}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2"
                                                                       Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Text="{Binding StatusLabel}"
                                                                       Foreground="{Binding StatusForeground}"
                                                                       FontSize="11"
                                                                       FontWeight="Bold" />
                                                            </Grid>

                                                        <WrapPanel Grid.Row="1" Margin="0,12,0,8">
                                                            <TextBlock Margin="0,0,12,6" Text="{Binding GroupName}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" />
                                                            <TextBlock Margin="0,0,12,6" Text="{Binding TypeLabel}" Foreground="{StaticResource WindowTextBrush}" FontSize="11" FontWeight="Bold" />
                                                            <TextBlock Margin="0,0,12,6" Text="收藏" Foreground="{StaticResource GoldBrush}" FontSize="11" FontWeight="Bold" Visibility="{Binding FavoriteVisibility}" />
                                                            <TextBlock Margin="0,0,12,6" Text="路径异常" Foreground="{StaticResource DangerBrush}" FontSize="11" FontWeight="Bold" Visibility="{Binding BrokenVisibility}" />
                                                        </WrapPanel>

                                                        <Border Grid.Row="2" Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="10" Margin="0,0,0,10">
                                                            <StackPanel>
                                                                <TextBlock Text="备注" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBlock Text="{Binding NoteSummaryText}" Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource WindowTextBrush}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Grid.Row="3" Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="10" Margin="0,0,0,10">
                                                            <StackPanel>
                                                                <TextBlock Text="启动参数" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                                <TextBlock Text="{Binding ArgumentsSummaryText}" Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource WindowTextBrush}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <WrapPanel Grid.Row="4" Margin="0,0,0,12">
                                                            <Border Style="{StaticResource TagBadgeStyle}" Background="{StaticResource SoftPanelBrush}" Padding="10,6">
                                                                <TextBlock Text="{Binding LastLaunchInlineText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                            </Border>
                                                            <Border Style="{StaticResource TagBadgeStyle}" Background="{StaticResource SoftPanelBrush}" Padding="10,6">
                                                                <TextBlock Text="{Binding LaunchCountInlineText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" />
                                                            </Border>
                                                        </WrapPanel>

                                                        <Grid Grid.Row="5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0" Content="启动" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="LaunchItemButton_Click" />
                                                            <Button Grid.Column="2" Content="目录" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="OpenFolderItemButton_Click" />
                                                            <Button Grid.Column="4" Content="编辑" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="EditItemButton_Click" />
                                                            <Button Grid.Column="6" Content="路径" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="CopyItemPathButton_Click" />
                                                            <Button Grid.Column="8" Content="{Binding FavoriteButtonCompactText}" Style="{StaticResource CardActionButtonStyle}" Tag="{Binding}" Click="ToggleFavoriteButton_Click" />
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="RightSidebarScrollViewer"
                                  Grid.Column="4"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  CanContentScroll="False">
                        <Grid x:Name="RightColumnGrid"
                              Width="{Binding ElementName=RightSidebarScrollViewer, Path=ViewportWidth}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border x:Name="CandidateSection" Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="22" Padding="16" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="从文件搜索加入当前分组" FontSize="12" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                                        <Border Grid.Column="1" Style="{StaticResource TagBadgeStyle}" Background="#FFE5F0EA" Margin="0">
                                            <TextBlock x:Name="CandidateCountText" Text="0 个候选" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock x:Name="CandidateHintText" Visibility="Collapsed" />
                                    <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="10" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock x:Name="CandidateNameText" Text="暂无候选" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock x:Name="CandidatePathText"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock x:Name="CandidateSuggestionText" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <ListBox x:Name="CandidateList"
                                             Margin="0,12,0,10"
                                             MinHeight="300"
                                             MaxHeight="300"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ScrollViewer.CanContentScroll="False"
                                             PreviewMouseLeftButtonDown="CandidateList_PreviewMouseLeftButtonDown"
                                             PreviewMouseWheel="CandidateList_PreviewMouseWheel"
                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                             ItemContainerStyle="{StaticResource CandidateListItemStyle}"
                                             SelectionChanged="CandidateList_SelectionChanged"
                                             MouseDoubleClick="CandidateList_MouseDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:ScanResultItem}">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="90" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="40" Height="40" CornerRadius="12" Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding InitialLetter}" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="0,4,0,0" Text="{Binding DirectoryNameDisplay}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding SuggestedGroupName}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <button:CButton x:Name="AddCandidateButton" Grid.Column="0" Content="加入分组" Height="34" Click="AddCandidateButton_Click" />
                                        <button:CButton x:Name="OpenCandidateFolderButton" Grid.Column="2" Content="目录" Height="34" Click="OpenCandidateFolderButton_Click" />
                                        <button:CButton x:Name="CopyCandidatePathButton" Grid.Column="4" Content="路径" Height="34" Click="CopyCandidatePathButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="22" Padding="16" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="最近活动" FontSize="12" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                                    <ItemsControl x:Name="ActivityList" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:StartupActivityVm}">
                                                <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding TimeText}" FontSize="12" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Summary}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="22" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="管理视图预览" FontSize="12" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="工作台视图负责高频启动，后续管理视图负责排序、批量编辑和字段维护。"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <Border Margin="0,14,0,0"
                                            Background="#FFFCFCFA"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <StackPanel>
                                            <Border Background="#FFEEF2EF" Padding="10,8" CornerRadius="16,16,0,0">
                                                <TextBlock Text="名称 | 分组 | 路径 | 参数 | 最近启动 | 状态 | 收藏 | 排序"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                            </Border>
                                            <TextBlock x:Name="ManagePreviewText"
                                                       Padding="12"
                                                       TextWrapping="Wrap"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FF445148" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Row="2"
                        Padding="18,14"
                        Background="#BFFFFFFF"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,30,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="StatusText" Text="就绪" FontSize="12" Foreground="{StaticResource WindowTextBrush}" />
                            <TextBlock x:Name="KeyboardHintText" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="关闭"
                                Width="88"
                                Style="{StaticResource ToolbarGhostButtonStyle}"
                                Margin="0"
                                Click="CloseButton_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
