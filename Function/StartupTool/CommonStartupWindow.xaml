<Window x:Class="PackageManager.Function.StartupTool.CommonStartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CustomControlLibrary.CustomControl.Controls;assembly=CustomControlLibrary"
        xmlns:button="clr-namespace:CustomControlLibrary.CustomControl.Controls.Button;assembly=CustomControlLibrary"
        xmlns:C="clr-namespace:CustomControlLibrary.CustomControl.Controls.DataGrid;assembly=CustomControlLibrary"
        Title="常用启动项"
        Height="680" Width="1000"
        MinHeight="500" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 搜索区 -->
            <RowDefinition Height="Auto"/>
            <!-- 分隔 -->
            <RowDefinition Height="8"/>
            <!-- 主体：左扫描结果 + 右常用列表 -->
            <RowDefinition Height="*"/>
            <!-- 底部按钮 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 搜索区 ===== -->
        <Border Grid.Row="0" Padding="12,10" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0"
                         Height="32" VerticalContentAlignment="Center"
                         Padding="8,0" FontSize="13"
                         BorderBrush="#CCCCCC" BorderThickness="1"
                         Background="#FAFAFA"
                         Text=""
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <VisualBrush x:Key="HintBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="输入文件名关键词，如 notepad、devenv、*.bat …"
                                                   Foreground="#AAAAAA" FontSize="13" Margin="8,0,0,0"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Background" Value="#FAFAFA"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <button:CButton Grid.Column="2" Content="重建索引" Width="88" Height="32"
                                Click="ScanButton_Click"/>
                <button:CButton Grid.Column="4" Content="停止" Width="72" Height="32"
                                x:Name="StopButton" IsEnabled="False"
                                Click="StopButton_Click"/>
            </Grid>
        </Border>

        <!-- ===== 主体 ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：扫描结果 -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0" Padding="12,8"
                            Background="#F8F8F8"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <controls:CTextBlock Grid.Column="0" Text="扫描结果"
                                                 FontSize="13" FontWeight="SemiBold"
                                                 VerticalAlignment="Center"/>
                            <controls:CTextBlock x:Name="ScanCountText" Grid.Column="1"
                                                 Text="" FontSize="12"
                                                 Foreground="#888888"
                                                 VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 结果列表 -->
                    <ListView x:Name="ScanResultList" Grid.Row="1"
                              BorderThickness="0" Background="Transparent"
                              SelectionMode="Extended"
                              MouseDoubleClick="ScanResultList_MouseDoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F7FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D6EAFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="13" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FullPath}"
                                                   FontSize="11" Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="+" Width="28" Height="28"
                                            FontSize="16" FontWeight="Bold"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#1976D2" Cursor="Hand"
                                            ToolTip="添加到常用启动项"
                                            Tag="{Binding}"
                                            Click="AddSingleItemButton_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 状态栏 -->
                    <Border Grid.Row="2" Padding="12,6"
                            Background="#F8F8F8"
                            BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <controls:CTextBlock x:Name="StatusText" Grid.Column="0"
                                                 Text="就绪" FontSize="12"
                                                 Foreground="#666666"
                                                 VerticalAlignment="Center"/>
                            <button:CButton Grid.Column="1" Content="批量添加选中项"
                                            Height="28" Padding="10,0"
                                            Click="AddSelectedButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 右：常用启动项 -->
            <Border Grid.Column="2" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0" Padding="12,8"
                            Background="#F8F8F8"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <controls:CTextBlock Grid.Column="0" Text="常用启动项"
                                                 FontSize="13" FontWeight="SemiBold"
                                                 VerticalAlignment="Center"/>
                            <button:CButton Grid.Column="1" Content="手动添加路径"
                                            Height="28" Padding="10,0"
                                            Click="ManualAddButton_Click"/>
                        </Grid>
                    </Border>

                    <!-- 启动项列表 -->
                    <ListView x:Name="StartupItemList" Grid.Row="1"
                              BorderThickness="0" Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F7FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D6EAFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FullPath}"
                                                   FontSize="11" Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding Note}"
                                                   FontSize="11" Foreground="#AAAAAA"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding NoteVisibility}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="▶" Width="28" Height="28"
                                                FontSize="13"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#2E7D32" Cursor="Hand"
                                                ToolTip="启动"
                                                Tag="{Binding}"
                                                Click="LaunchItemButton_Click"/>
                                        <Button Content="✎" Width="28" Height="28"
                                                FontSize="13"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#1565C0" Cursor="Hand"
                                                ToolTip="编辑"
                                                Tag="{Binding}"
                                                Click="EditItemButton_Click"/>
                                        <Button Content="✕" Width="28" Height="28"
                                                FontSize="13"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#C62828" Cursor="Hand"
                                                ToolTip="删除"
                                                Tag="{Binding}"
                                                Click="RemoveItemButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 底部提示 -->
                    <Border Grid.Row="2" Padding="12,6"
                            Background="#F8F8F8"
                            BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                        <controls:CTextBlock Text="双击扫描结果可快速添加；点击 ▶ 直接启动"
                                             FontSize="11" Foreground="#999999"
                                             VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 底部 ===== -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <button:CButton Content="关闭" Width="80" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
